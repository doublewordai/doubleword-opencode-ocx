{
  "name": "doubleword-async-tool",
  "versions": {
    "1.0.0": {
      "name": "doubleword-async-tool",
      "type": "tool",
      "description": "MCP tool set 'doubleword_async' — primary blocking tool returns flex completions directly; fallback pair (submit_async_job + get_async_result) for explicit non-blocking use when the user chooses to wait and check later.",
      "files": [
        {
          "path": "mcp/dw_async_mcp.py",
          "target": "tool/doubleword-async/dw_async_mcp.py"
        }
      ],
      "dependencies": [],
      "opencode": {
        "mcp": {
          "doubleword-async": {
            "type": "local",
            "command": [
              "python3",
              "{env:HOME}/.config/opencode/tools/doubleword-async/dw_async_mcp.py"
            ],
            "environment": {
              "DOUBLEWORD_API_KEY": "{env:DOUBLEWORD_API_KEY}"
            },
            "enabled": true
          }
        }
      }
    }
  },
  "dist-tags": {
    "latest": "1.0.0"
  }
}