{
  "name": "doubleword",
  "versions": {
    "1.0.0": {
      "name": "doubleword",
      "type": "bundle",
      "description": "Doubleword for opencode: realtime + flex (async) providers, small_model pin, async MCP tool, and a flex background subagent. Requires DOUBLEWORD_API_KEY in your environment.",
      "files": [],
      "dependencies": [
        "doubleword-async-tool",
        "doubleword-flex-agent"
      ],
      "opencode": {
        "small_model": "doubleword/moonshotai/Kimi-K2.6",
        "provider": {
          "doubleword": {
            "name": "Doubleword",
            "npm": "@ai-sdk/openai-compatible",
            "options": {
              "baseURL": "https://api.doubleword.ai/v1",
              "apiKey": "{env:DOUBLEWORD_API_KEY}"
            },
            "models": {
              "moonshotai/Kimi-K2.6": {
                "id": "moonshotai/Kimi-K2.6",
                "name": "Kimi K2.6",
                "tool_call": true,
                "limit": {
                  "context": 128000,
                  "output": 8192
                }
              },
              "zai-org/GLM-5.2-FP8": {
                "id": "zai-org/GLM-5.2-FP8",
                "name": "GLM-5.2",
                "tool_call": true,
                "limit": {
                  "context": 128000,
                  "output": 8192
                }
              }
            }
          },
          "doubleword-flex": {
            "name": "Doubleword (flex)",
            "npm": "@ai-sdk/openai-compatible",
            "options": {
              "baseURL": "https://api.doubleword.ai/v1",
              "apiKey": "{env:DOUBLEWORD_API_KEY}",
              "timeout": false,
              "headerTimeout": false
            },
            "models": {
              "moonshotai/Kimi-K2.6": {
                "id": "moonshotai/Kimi-K2.6",
                "name": "Kimi K2.6 (flex)",
                "tool_call": true,
                "limit": {
                  "context": 128000,
                  "output": 8192
                },
                "options": {
                  "service_tier": "flex"
                }
              },
              "zai-org/GLM-5.2-FP8": {
                "id": "zai-org/GLM-5.2-FP8",
                "name": "GLM-5.2 (flex)",
                "tool_call": true,
                "limit": {
                  "context": 128000,
                  "output": 8192
                },
                "options": {
                  "service_tier": "flex"
                }
              }
            }
          }
        }
      }
    }
  },
  "dist-tags": {
    "latest": "1.0.0"
  }
}