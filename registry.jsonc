{
  // Doubleword × opencode registry
  // Realtime + flex (async) providers, plus an async MCP tool, for opencode.
  // Schema: https://ocx.kdco.dev/schemas/v2/registry.json
  "$schema": "https://ocx.kdco.dev/schemas/v2/registry.json",
  "name": "Doubleword",
  "version": "0.1.0",
  "author": "Doubleword",
  "opencode": "1.0.0",
  "ocx": "1.0.16",

  "components": [
    {
      // One-command setup: providers (realtime + flex) + small_model pin,
      // and pulls in the async MCP tool + flex subagent.
      "name": "doubleword",
      "type": "bundle",
      "description": "Doubleword for opencode: realtime + flex (async) providers, small_model pin, async MCP tool, and a flex background subagent. Requires DOUBLEWORD_API_KEY in your environment.",
      "files": [],
      "dependencies": ["doubleword-async-tool", "doubleword-flex-agent"],
      "opencode": {
        // keep title/summary generation on the fast realtime tier
        "small_model": "doubleword/moonshotai/Kimi-K2.6",
        "provider": {
          "doubleword": {
            "name": "Doubleword",
            "npm": "@ai-sdk/openai-compatible",
            "options": {
              "baseURL": "https://api.doubleword.ai/v1",
              "apiKey": "{env:DOUBLEWORD_API_KEY}"
            },
            "models": {
              "moonshotai/Kimi-K2.6": { "id": "moonshotai/Kimi-K2.6", "name": "Kimi K2.6", "tool_call": true, "limit": { "context": 128000, "output": 8192 } },
              "zai-org/GLM-5.2-FP8": { "id": "zai-org/GLM-5.2-FP8", "name": "GLM-5.2", "tool_call": true, "limit": { "context": 128000, "output": 8192 } }
            }
          },
          "doubleword-flex": {
            "name": "Doubleword (flex)",
            "npm": "@ai-sdk/openai-compatible",
            "options": {
              "baseURL": "https://api.doubleword.ai/v1",
              "apiKey": "{env:DOUBLEWORD_API_KEY}",
              "timeout": false,
              "headerTimeout": false
            },
            "models": {
              "moonshotai/Kimi-K2.6": { "id": "moonshotai/Kimi-K2.6", "name": "Kimi K2.6 (flex)", "tool_call": true, "limit": { "context": 128000, "output": 8192 }, "options": { "service_tier": "flex" } },
              "zai-org/GLM-5.2-FP8": { "id": "zai-org/GLM-5.2-FP8", "name": "GLM-5.2 (flex)", "tool_call": true, "limit": { "context": 128000, "output": 8192 }, "options": { "service_tier": "flex" } }
            }
          }
        }
      }
    },
    {
      // Async (flex) as a discrete MCP tool — flex result returned as a tool result.
      "name": "doubleword-async-tool",
      "type": "tool",
      "description": "MCP tool 'doubleword_async' — runs a prompt on Doubleword's flex (async) tier and returns the text. Useful for fire-and-forget async jobs from any model/agent.",
      "files": [
        { "path": "mcp/dw_async_mcp.py", "target": "tool/doubleword-async/dw_async_mcp.py" }
      ],
      "opencode": {
        "mcp": {
          "doubleword-async": {
            "type": "local",
            "command": ["python3", "{env:HOME}/.config/opencode/tools/doubleword-async/dw_async_mcp.py"],
            "environment": { "DOUBLEWORD_API_KEY": "{env:DOUBLEWORD_API_KEY}" },
            "timeout": 900000
          }
        }
      }
    },
    {
      // Background subagent pinned to the flex tier for non-urgent work.
      "name": "doubleword-flex-agent",
      "type": "agent",
      "description": "Subagent 'dw-flex' pinned to Doubleword's flex tier — for non-urgent, self-contained work dispatched in the background.",
      "files": [
        { "path": "agent/dw-flex.md", "target": "agent/dw-flex.md" }
      ]
    }
  ]
}
